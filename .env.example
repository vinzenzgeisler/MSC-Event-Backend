AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Cognito Hosted UI / OAuth (CDK AuthStack)
COGNITO_CALLBACK_URLS_DEV=http://localhost:5173/auth/callback
COGNITO_LOGOUT_URLS_DEV=http://localhost:5173/
COGNITO_DOMAIN_PREFIX_DEV=
COGNITO_CALLBACK_URLS_PROD=
COGNITO_LOGOUT_URLS_PROD=
COGNITO_DOMAIN_PREFIX_PROD=

# Public registration verify-link used in registration_received mail template
PUBLIC_VERIFY_BASE_URL_DEV=http://localhost:5173/anmeldung/verify
PUBLIC_VERIFY_BASE_URL_PROD=

# S3 assets upload CORS allow-list (CSV)
ASSETS_CORS_ALLOWED_ORIGINS_DEV=http://localhost:5173,http://localhost:4173
ASSETS_CORS_ALLOWED_ORIGINS_PROD=

# Dev cleanup scheduler (stops tagged RDS every 6h) - keep false while actively testing
DEV_CLEANUP_ENABLED=false
