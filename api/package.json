    "@aws-sdk/rds-signer": "^3.645.0",
    "@aws-sdk/s3-request-presigner": "^3.645.0",
    "@types/aws-lambda": "^8.10.137",
    "drizzle-orm": "^0.33.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.4",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.24.0",
