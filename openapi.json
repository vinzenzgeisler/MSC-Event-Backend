{
  "openapi": "3.1.0",
  "info": {
    "title": "MSC Event Backend API",
    "version": "0.1.0"
  },
  "paths": {
    "/public/events/current": {
      "get": {
        "operationId": "getPublicCurrentEvent",
        "responses": {
          "200": {
            "description": "Current event with classes, registration window and pricing rules."
          }
        }
      }
    },
    "/public/events/{id}/entries": {
      "post": {
        "operationId": "createPublicEntry",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entry created"
          }
        }
      }
    },
    "/public/entries/{id}/verify-email": {
      "post": {
        "operationId": "verifyPublicEntryEmail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Email verification result"
          }
        }
      }
    },
    "/admin/auth/me": {
      "get": {
        "operationId": "getAdminAuthMe",
        "responses": {
          "200": {
            "description": "Auth context including roles and mfaAuthenticated."
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden (including MFA_REQUIRED for admin)"
          }
        }
      }
    }
  }
}
