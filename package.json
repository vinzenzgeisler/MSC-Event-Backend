{
  "name": "dreiecksrennen",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "api",
    "infra"
  ],
  "scripts": {
    "build": "npm run -ws --if-present build",
    "infra:build": "npm --workspace infra run build",
    "synth": "npm --workspace infra run synth",
    "synth:academy": "node scripts/academy-cdk.js academy synth",
    "synth:private": "node scripts/academy-cdk.js private synth",
    "bootstrap:academy": "node scripts/academy-cdk.js academy bootstrap",
    "bootstrap:private": "node scripts/academy-cdk.js private bootstrap",
    "deploy": "npm --workspace infra run deploy",
    "deploy:academy": "node scripts/academy-cdk.js academy deploy",
    "deploy:private": "node scripts/academy-cdk.js private deploy",
    "diff": "npm --workspace infra run diff",
    "diff:academy": "node scripts/academy-cdk.js academy diff",
    "diff:private": "node scripts/academy-cdk.js private diff",
    "api:build": "npm --workspace api run build",
    "api:db:generate": "npm --workspace api run db:generate",
    "api:db:migrate": "npm --workspace api run db:migrate",
    "api:seed:dev-current-event": "npm --workspace api run seed:dev-current-event",
    "api:start": "npm --workspace api run start"
  }
}
